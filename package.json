{
  "name": "cs2-discord-clutch",
  "version": "1.0.0",
  "description": "CS2 companion tool that lowers Discord voice chat volume during clutch situations",
  "main": "src/electron/main.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/main.ts",
    "build:ts": "tsc",
    "start": "node dist/main.js",
    "test:normal": "ts-node src/testing/send-test-payload.ts normal",
    "test:clutch": "ts-node src/testing/send-test-payload.ts clutch",
    "test:death": "ts-node src/testing/send-test-payload.ts death",
    "test:roundend": "ts-node src/testing/send-test-payload.ts roundend",
    "test:discord": "ts-node src/testing/discord-diagnostics.ts",
    "test:module": "ts-node src/testing/test-module.ts",
    "test:connection": "ts-node src/testing/test-connection.ts",
    "electron:overlay": "electron src/electron/main.js",
    "electron:dev": "electron src/electron/main.js",
    "clean": "node -e \"const fs=require('fs');if(fs.existsSync('dist'))fs.rmSync('dist',{recursive:true,force:true})\"",
    "electron:prebuild": "npm run clean && npm run build:ts",
    "electron:build": "npm run electron:prebuild && electron-builder --win --config electron-builder.json",
    "electron:pack": "npm run electron:prebuild && electron-builder --win --dir --config electron-builder.json",
    "electron:dist": "npm run electron:build",
    "ow:start": "ow-electron .",
    "ow:dev": "npm run build:ts && ow-electron .",
    "ow:build": "npm run build:ts && ow-electron-builder --publish=never"
  },
  "keywords": [
    "cs2",
    "counter-strike",
    "discord",
    "gsi",
    "voice",
    "clutch"
  ],
  "author": {
    "name": "Strife"
  },
  "license": "MIT",
  "dependencies": {
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "smart-buffer": "^4.2.0",
    "zod": "^3.22.4"
  },
  "optionalDependencies": {
    "discord-rpc": "^4.0.1"
  },
  "devDependencies": {
    "@overwolf/ow-electron": "^39.6.0",
    "@overwolf/ow-electron-builder": "^26.0.12",
    "@types/body-parser": "^1.19.5",
    "@types/discord-rpc": "^4.0.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "productName": "CS2 Clutch Mode",
  "overwolf": {
    "packages": [
      "gep",
      "overlay"
    ]
  },
  "build": {
    "nodeGypRebuild": false,
    "appId": "com.strife.cs2clutchmode.overwolf",
    "asar": false,
    "overwolf": {
      "disableAdOptimization": false
    },
    "productName": "CS2 Clutch Mode",
    "directories": {
      "output": "dist-overwolf"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "config/**/*",
      "node_modules/**/*",
      "package.json",
      "!src/testing/**",
      "!dist/testing/**",
      "!dist/electron/**",
      "!**/*.ts",
      "!**/*.d.ts",
      "!**/*.ts.map",
      "!**/*.d.ts.map",
      "!**/*.js.map",
      "!**/tsconfig.json"
    ],
    "copyright": "Copyright 2026 Strife",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "CS2-Clutch-Mode-Overwolf-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
